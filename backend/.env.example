# ── Server ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────
# Local:  mongodb://localhost:27017/chatify
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/chatify
MONGO_URI=your_mongo_uri_here

# ── Authentication ────────────────────────────────────────
# Generate a secure random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here

# ── Frontend URL (for CORS and email links) ───────────────
CLIENT_URL=http://localhost:5173

# ── Cloudinary (image uploads) ────────────────────────────
# Sign up at https://cloudinary.com and grab these from the dashboard
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ── Resend (welcome emails — optional) ────────────────────
# Sign up at https://resend.com — leave blank to skip welcome emails
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=onboarding@yourdomain.com
EMAIL_FROM_NAME=Chatify

# ── Arcjet (rate limiting & bot protection — optional) ────
# Sign up at https://arcjet.com
ARCJET_KEY=your_arcjet_key
ARCJET_ENV=development